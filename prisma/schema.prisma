generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Teacher
  Walikelas
  KepalaSekolah
  Siswa
}

model CatatanAbsensi {
  id                Int      @id @default(autoincrement())
  timestamp_absensi DateTime
  status            String
  createdAt         DateTime @default(now())
  karyawanId        Int
  karyawan          Karyawan @relation(fields: [karyawanId], references: [id])

  @@map("CatatanAbsensi")
}

model PengaturanAbsensi {
  id                Int      @id @default(autoincrement())
  waktuMulaiAbsen   String
  batasTepatWaktu   String
  batasTerlambat    String
  waktuMulaiPulang  String   @default("16:00") // Default checkout start time
  batasWaktuPulang  String   @default("18:00") // Default checkout end time
  hariKerja         String[] // array string PostgreSQL
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("PengaturanAbsensi")
}

model Karyawan {
  id             Int              @id @default(autoincrement())
  nama           String
  nip            String           @unique
  foto_filename  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  face_embedding String?
  email          String?          @unique
  password       String?
  status         Role           @default(Siswa)
  catatanAbsensi CatatanAbsensi[]
  uangSekolah    UangSekolah[]
  jadwalMengajar JadwalPelajaran[]
  kelasId        Int?
  kelas          Kelas?         @relation("SiswaKelas", fields: [kelasId], references: [id])
  kelasDiwalikan Kelas[]        @relation("WaliKelas")
  rapor          Rapor[]

  @@map("Karyawan")
}

model HariLibur {
  id          Int      @id @default(autoincrement())
  tanggal     DateTime
  keterangan  String   @default("Hari Libur")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tanggal])
  @@map("HariLibur")
}

model UangSekolah {
  id          Int      @id @default(autoincrement())
  siswaId     Int
  siswa       Karyawan @relation(fields: [siswaId], references: [id])
  bulan       Int
  tahun       Int
  jumlah      Int
  status      String   @default("Belum Lunas") // Belum Lunas, Lunas
  tanggalBayar DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("UangSekolah")
}

model TahunAkademik {
  id        Int      @id @default(autoincrement())
  tahun     String   // e.g., "2024/2025"
  semester  String   // e.g., "Ganjil" or "Genap"
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jadwal    JadwalPelajaran[]
  rapor     Rapor[]

  @@map("TahunAkademik")
}

model MataPelajaran {
  id          Int      @id @default(autoincrement())
  nama        String
  deskripsi   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jadwal      JadwalPelajaran[]
  nilai       Nilai[]

  @@map("MataPelajaran")
}

model Kelas {
  id          Int      @id @default(autoincrement())
  nama        String   // e.g., "X IPA 1"
  walikelasId Int?
  walikelas   Karyawan? @relation("WaliKelas", fields: [walikelasId], references: [id])
  siswa       Karyawan[] @relation("SiswaKelas")
  jadwal      JadwalPelajaran[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Kelas")
}

model JadwalPelajaran {
  id              Int          @id @default(autoincrement())
  tahunAkademikId Int
  tahunAkademik   TahunAkademik @relation(fields: [tahunAkademikId], references: [id])
  kelasId         Int
  kelas           Kelas        @relation(fields: [kelasId], references: [id])
  mataPelajaranId Int
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id])
  guruId          Int
  guru            Karyawan     @relation(fields: [guruId], references: [id])
  hari            String       // e.g., "Senin"
  waktuMulai      String       // e.g., "07:00"
  waktuSelesai    String       // e.g., "08:30"
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("JadwalPelajaran")
}

model Rapor {
  id              Int      @id @default(autoincrement())
  siswaId         Int
  siswa           Karyawan @relation(fields: [siswaId], references: [id])
  tahunAkademikId Int
  tahunAkademik   TahunAkademik @relation(fields: [tahunAkademikId], references: [id])
  catatanWalikelas String?
  nilai           Nilai[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("Rapor")
}

model Nilai {
  id              Int      @id @default(autoincrement())
  raporId         Int
  rapor           Rapor    @relation(fields: [raporId], references: [id])
  mataPelajaranId Int
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id])
  nilai           Int
  catatanGuru     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("Nilai")
}


